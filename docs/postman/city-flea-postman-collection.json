{
  "info": {
    "_postman_id": "city-flea-postman-collection",
    "name": "city-flea 同城跳蚤市场 - 邮政寄送模块",
    "description": "同城跳蚤市场系统邮政寄送模块 API 测试集合\n\n**使用说明**：\n1. 先执行「认证模块」下的接口获取 token\n2. token 会自动保存到集合变量中\n3. 然后执行其他接口\n\n**测试环境**：\n- 基础URL：http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "v2.1.0"
  },
  "item": [
    {
      "name": "1. 认证模块",
      "item": [
        {
          "name": "1.1 用户登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"test123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/user/user/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "user",
                "login"
              ]
            },
            "description": "用户微信登录，获取认证 token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"登录成功\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(1);",
                  "    if (jsonData.data && jsonData.data.token) {",
                  "        pm.collectionVariables.set(\"userToken\", jsonData.data.token);",
                  "        console.log(\"用户 Token 已保存:\", jsonData.data.token);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 管理员登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/employee/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "employee",
                "login"
              ]
            },
            "description": "管理员登录，获取认证 token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"登录成功\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(1);",
                  "    if (jsonData.data && jsonData.data.token) {",
                  "        pm.collectionVariables.set(\"adminToken\", jsonData.data.token);",
                  "        console.log(\"管理员 Token 已保存:\", jsonData.data.token);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        }
      ],
      "description": "用户和管理员登录认证接口"
    },
